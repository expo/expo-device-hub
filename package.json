{
  "name": "expo-serve-device-monorepo",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck --filter='!./packages/serve-sim/packages/*' --filter='!./packages/serve-emu/packages/*'",
    "lint": "turbo run lint --filter='!./packages/serve-sim/packages/*' --filter='!./packages/serve-emu/packages/*'",
    "test": "turbo run test --filter='!./packages/serve-sim/packages/*' --filter='!./packages/serve-emu/packages/*'",
    "clean": "turbo run clean --filter='!./packages/serve-sim/packages/*' --filter='!./packages/serve-emu/packages/*'",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "workspaces": {
    "packages": [
      "packages/expo-device-hub",
      "packages/@expo/hub-*",
      "packages/serve-sim/packages/*",
      "packages/serve-emu/packages/*",
      "example"
    ],
    "catalog": {
      "@expo/metro-runtime": "~57.0.3",
      "expo": "~57.0.4",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "react-native": "0.86.0",
      "react-native-web": "^0.21.2"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/bun": "^1.3.14",
    "turbo": "^2.10.2"
  }
}
