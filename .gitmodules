# FIXME: the serve-sim submodule packages (packages/serve-sim, packages/serve-sim-client)
# declare Apache-2.0 but ship no LICENSE file in the package directories (only the repo root
# has one); the previously vendored copy included per-package LICENSE files.
[submodule "packages/serve-sim"]
	path = packages/serve-sim
	url = https://github.com/expo/serve-sim.git
	branch = expo
	ignore = untracked
