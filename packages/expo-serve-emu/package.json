{
  "name": "expo-serve-emu",
  "version": "0.1.0",
  "description": "DevTools plugin that serves the serve-emu Android emulator preview from the Expo CLI",
  "sideEffects": false,
  "keywords": [
    "expo",
    "devtools",
    "emulator",
    "android"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "expo-module.config.json"
  ],
  "scripts": {
    "build": "swc src/index.ts -o dist/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "serve-emu": "*"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^25.6.2",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "expo": "*"
  }
}
