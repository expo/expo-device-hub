{
  "name": "expo-serve-device",
  "version": "0.1.0",
  "description": "DevTools plugin for serving on device",
  "sideEffects": false,
  "scripts": {
    "build:all": "bun run web:export",
    "clean": "rm -rf dist",
    "web:dev": "cd ../expo-serve-device-webui && npx expo start -w",
    "web:export": "./scripts/build-webui.js"
  },
  "keywords": [
    "expo",
    "devtools"
  ],
  "files": [
    "cli",
    "dist",
    "expo-module.config.json"
  ],
  "license": "MIT",
  "dependencies": {
    "serve-sim": "*"
  },
  "peerDependencies": {
    "expo": "*"
  }
}
