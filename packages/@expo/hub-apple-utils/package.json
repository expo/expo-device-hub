{
  "name": "@expo/hub-apple-utils",
  "version": "0.1.0",
  "private": true,
  "description": "List connected Apple devices via devicectl.",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "os": [
    "darwin"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "swc src --out-dir dist --strip-leading-paths",
    "clean": "rm -rf dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bun": "latest",
    "@types/node": "^25.6.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
