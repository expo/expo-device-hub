{
  "name": "serve-emu",
  "version": "0.0.3",
  "description": "The `npx serve` of Android devices — stream a booted emulator or attached device over a WebSocket H.264 feed decoded in the browser with WebCodecs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/middleware.js",
  "module": "./dist/middleware.js",
  "types": "./dist/middleware.d.ts",
  "exports": {
    ".": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./stream-socket": {
      "types": "./dist/stream-socket.d.ts",
      "import": "./dist/stream-socket.js"
    }
  },
  "sideEffects": false,
  "author": "jiunshinn",
  "homepage": "https://github.com/jiunshinn/serve-emu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiunshinn/serve-emu.git",
    "directory": "packages/serve-emu"
  },
  "bugs": {
    "url": "https://github.com/jiunshinn/serve-emu/issues"
  },
  "keywords": [
    "android",
    "emulator",
    "adb",
    "scrcpy",
    "screen-mirror",
    "remote-control",
    "h264",
    "webcodecs",
    "bun"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "serve-emu": "./src/cli.ts"
  },
  "scripts": {
    "setup": "bun run scripts/fetch-scrcpy.ts && bun run build:ui",
    "dev": "bun --watch run src/cli.ts",
    "dev:ui": "vite",
    "start": "bun run src/cli.ts",
    "build:ui": "vite build",
    "build:lib": "swc src -d dist --strip-leading-paths && tsc -p tsconfig.build.json && node scripts/fix-dist-imports.mjs",
    "build": "bun run clean && bun run build:ui && bun run build:lib",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "tsc -p src/ui --noEmit",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "src",
    "scripts",
    "vendor",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^5.4.11"
  }
}
