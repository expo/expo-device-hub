{
  "$schema": "https://swc.rs/schema.json",
  "exclude": ["\\.test\\.tsx?$", "__tests__"],
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true
    },
    "transform": {
      "react": {
        "runtime": "automatic"
      }
    },
    "target": "es2022"
  },
  "module": {
    "type": "es6"
  },
  "sourceMaps": true
}
